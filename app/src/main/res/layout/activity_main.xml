<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FB"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- 안전한 QR코드 스캐너 상단 배너 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_background2"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <!-- QR 아이콘과 텍스트 수평 배치 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_qr_code"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@string/ic_qr_code_description" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="안전한 QR 스캐너"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- 하단 설명 배너 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_transparent_background"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="8dp"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/shieldIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_shield_check"
                    app:tint="#64DD17"
                    android:contentDescription="@string/ic_shield_description"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="큐싱(Qushing) 예방 솔루션"
                    android:textSize="16sp"
                    android:textColor="#E3F2FD" />
            </LinearLayout>
        </LinearLayout>

        <!-- QR 코드 스캔 영역 -->
        <LinearLayout
            android:id="@+id/qrScanButton"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/rounded_background"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_qr_code"
                app:tint="#2563EB" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QR 코드를 스캔하려면 클릭하세요"
                android:textColor="#2563EB"
                android:textSize="16sp"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- 정보 카드 -->

            <LinearLayout
                android:id="@+id/qushingInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:padding="15dp"
                android:background="@drawable/rounded_background"
                android:orientation="horizontal"
                android:clickable="true"
                android:foreground="?attr/selectableItemBackground">



            <!-- 화살표 아이콘 -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_right"
                app:tint="#757575"
                android:layout_marginEnd="8dp" />

            <!-- 텍스트 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="큐싱(Qushing) 이란?"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
